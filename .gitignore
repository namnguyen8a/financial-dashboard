logs/

# ==============================================================================
# Security & Credentials (CRITICAL - Never commit these)
# ==============================================================================
.env
.env.*
!.env.example  # DO NOT ignore the example file so team members know what variables to set
*.pem
*.key
*.secret
*.cert

